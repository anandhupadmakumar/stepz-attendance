rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection — only authenticated users can read their own doc
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Allow admin to read all user docs (by role check)
      allow read: if request.auth != null;
    }

    // Attendance collection — employees can write/read their own records
    match /attendance/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      // Admin can read all attendance records
      allow read: if request.auth != null;
    }

    // Settings — only readable by authenticated users, writable by admin role
    match /settings/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
